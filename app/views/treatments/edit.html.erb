<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1">Edit Treatment</h1>
    <p class="text-muted mb-0">
      Update this treatment for <%= @appointment.pet.name %>'s appointment.
    </p>
  </div>

  <%= link_to appointment_path(@appointment), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-1"></i>
    Back to Appointment
  <% end %>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <p class="text-muted mb-1">Appointment Date</p>
        <p class="fw-semibold mb-0"><%= format_datetime(@appointment.date) %></p>
      </div>

      <div class="col-md-4">
        <p class="text-muted mb-1">Pet</p>
        <p class="fw-semibold mb-0"><%= @appointment.pet.name %></p>
      </div>

      <div class="col-md-4">
        <p class="text-muted mb-1">Vet</p>
        <p class="fw-semibold mb-0"><%= @appointment.vet.full_name %></p>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <%= render "form", appointment: @appointment, treatment: @treatment %>
  </div>
</div>