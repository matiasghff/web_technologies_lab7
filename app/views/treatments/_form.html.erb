<%= render "shared/error_messages", object: treatment %>

<%= form_with(model: [appointment, treatment]) do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :medication, class: "form-label" %>
    <%= form.text_field :medication, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :dosage, class: "form-label" %>
    <%= form.text_field :dosage, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :administered_at, class: "form-label" %>
    <%= form.datetime_field :administered_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :clinical_notes, "Clinical notes", class: "form-label" %>
    <%= form.rich_text_area :clinical_notes, class: "form-control" %>

    <div class="form-text">
      Use this field for formatted clinical notes, including headings, bold text, lists, and links.
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", appointment_path(appointment), class: "btn btn-outline-secondary" %>
  </div>
<% end %>