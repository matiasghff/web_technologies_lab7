<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1">Vets</h1>
    <p class="text-muted mb-0">Meet and manage the clinic veterinarians.</p>
  </div>

  <div>
    <%= link_to new_vet_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle me-1"></i>
      New Vet
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Full Name</th>
            <th>Email</th>
            <th>Specialization</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% @vets.each do |vet| %>
            <tr>
              <td class="ps-4">
                <%= link_to vet.full_name,
                  vet_path(vet),
                  class: "fw-semibold text-decoration-none" %>
              </td>

              <td>
                <span class="text-muted">
                  <%= vet.email %>
                </span>
              </td>

              <td>
                <span class="badge bg-info-subtle text-info">
                  <%= vet.specialization %>
                </span>
              </td>

              <td class="text-end pe-4">
                <div class="d-flex flex-column flex-md-row justify-content-md-end gap-2">
                  <%= link_to vet_path(vet), class: "btn btn-sm btn-outline-primary" do %>
                    <i class="bi bi-eye me-1"></i>
                    Show
                  <% end %>

                  <%= link_to new_appointment_path(vet_id: vet.id), class: "btn btn-sm btn-outline-success" do %>
                    <i class="bi bi-calendar-plus me-1"></i>
                    Schedule
                  <% end %>

                  <%= link_to edit_vet_path(vet), class: "btn btn-sm btn-outline-secondary" do %>
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit
                  <% end %>

                  <%= button_to vet_path(vet),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-sm btn-outline-danger" do %>
                    <i class="bi bi-trash me-1"></i>
                    Delete
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @vets.empty? %>
            <tr>
              <td colspan="4" class="text-center text-muted py-4">
                No vets found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>