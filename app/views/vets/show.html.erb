<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1"><%= @vet.full_name %></h1>
    <p class="text-muted mb-0">Review veterinarian information and schedule appointments.</p>
  </div>

  <div class="d-flex flex-column flex-md-row gap-2">
    <%= link_to new_appointment_path(vet_id: @vet.id), class: "btn btn-primary" do %>
      <i class="bi bi-calendar-plus me-1"></i>
      Schedule Appointment
    <% end %>

    <%= link_to edit_vet_path(@vet), class: "btn btn-outline-secondary" do %>
      <i class="bi bi-pencil-square me-1"></i>
      Edit Vet
    <% end %>

    <%= link_to vets_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Vets
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-12 col-lg-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <h2 class="h4 mb-3">Vet Details</h2>

        <div class="mb-3">
          <p class="text-muted mb-1">Email</p>
          <p class="fw-semibold mb-0"><%= @vet.email %></p>
        </div>

        <div class="mb-3">
          <p class="text-muted mb-1">Phone</p>
          <p class="fw-semibold mb-0"><%= @vet.phone %></p>
        </div>

        <div class="mb-4">
          <p class="text-muted mb-1">Specialization</p>
          <span class="badge bg-info-subtle text-info">
            <%= @vet.specialization %>
          </span>
        </div>

        <%= button_to vet_path(@vet),
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "btn btn-outline-danger w-100" do %>
          <i class="bi bi-trash me-1"></i>
          Delete Vet
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
          <div>
            <h2 class="h4 mb-1">Vet Schedule</h2>
            <p class="text-muted mb-0">Upcoming appointments for this veterinarian.</p>
          </div>

          <%= link_to new_appointment_path(vet_id: @vet.id), class: "btn btn-sm btn-primary" do %>
            <i class="bi bi-calendar-plus me-1"></i>
            Schedule
          <% end %>
        </div>
      </div>

      <div class="card-body">
        <% upcoming_appointments = @vet.appointments.upcoming.includes(:pet) %>

        <% if upcoming_appointments.any? %>
          <div class="list-group list-group-flush">
            <% upcoming_appointments.each do |appointment| %>
              <%= link_to appointment_path(appointment), class: "list-group-item list-group-item-action px-0" do %>
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                  <div>
                    <div class="fw-semibold">
                      <i class="bi bi-clock me-1"></i>
                      <%= format_datetime(appointment.date) %>
                    </div>

                    <small class="text-muted">
                      Pet: <%= appointment.pet.name %> · <%= truncate(appointment.reason, length: 50) %>
                    </small>
                  </div>

                  <% badge_class =
                    case appointment.status
                    when "scheduled" then "bg-primary-subtle text-primary"
                    when "in_progress" then "bg-warning-subtle text-warning"
                    when "completed" then "bg-success-subtle text-success"
                    when "cancelled" then "bg-danger-subtle text-danger"
                    else "bg-secondary-subtle text-secondary"
                    end %>

                  <span class="badge <%= badge_class %>">
                    <%= human_status(appointment.status) %>
                  </span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-calendar-check fs-1 d-block mb-3"></i>
            <p class="mb-3">This vet has no upcoming appointments.</p>

            <%= link_to new_appointment_path(vet_id: @vet.id), class: "btn btn-primary" do %>
              <i class="bi bi-calendar-plus me-1"></i>
              Schedule First Appointment
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>