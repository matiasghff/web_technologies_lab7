<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1">Owners</h1>
    <p class="text-muted mb-0">Manage and review all pet owners.</p>
  </div>

  <div>
    <%= link_to new_owner_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle me-1"></i>
      New Owner
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Full Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Pets</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% @owners.each do |owner| %>
            <tr>
              <td class="ps-4">
                <%= link_to "#{owner.first_name} #{owner.last_name}",
                  owner_path(owner),
                  class: "fw-semibold text-decoration-none" %>
              </td>

              <td>
                <span class="text-muted">
                  <%= owner.email %>
                </span>
              </td>

              <td>
                <span class="text-muted">
                  <%= owner.phone %>
                </span>
              </td>

              <td>
                <span class="badge bg-primary-subtle text-primary">
                  <%= pluralize(owner.pets.size, "pet") %>
                </span>
              </td>

              <td class="text-end pe-4">
                <div class="d-flex flex-column flex-md-row justify-content-md-end gap-2">
                  <%= link_to owner_path(owner), class: "btn btn-sm btn-outline-primary" do %>
                    <i class="bi bi-eye me-1"></i>
                    Show
                  <% end %>

                  <%= link_to edit_owner_path(owner), class: "btn btn-sm btn-outline-secondary" do %>
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit
                  <% end %>

                  <%= button_to owner_path(owner),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-sm btn-outline-danger" do %>
                    <i class="bi bi-trash me-1"></i>
                    Delete
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @owners.empty? %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">
                No owners found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>