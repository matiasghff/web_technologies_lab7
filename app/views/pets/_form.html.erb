<%= render "shared/error_messages", object: pet %>

<%= form_with(model: pet) do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :species, class: "form-label" %>
    <%= form.select :species,
      ["dog", "cat", "rabbit", "bird", "reptile", "other"],
      { prompt: "Select species" },
      class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :breed, class: "form-label" %>
    <%= form.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :date_of_birth, class: "form-label" %>
    <%= form.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :weight, class: "form-label" %>
    <%= form.number_field :weight, step: 0.1, min: 0, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :owner_id, "Owner", class: "form-label" %>
    <%= form.collection_select :owner_id,
      Owner.order(:last_name, :first_name),
      :id,
      :full_name,
      { prompt: "Select owner" },
      class: "form-select" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", pets_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>