<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1">Pets</h1>
    <p class="text-muted mb-0">Browse pets and their owners.</p>
  </div>

  <div>
    <%= link_to new_pet_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle me-1"></i>
      New Pet
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Photo</th>
            <th>Name</th>
            <th>Species</th>
            <th>Breed</th>
            <th>Owner</th>
            <th>Date of Birth</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% @pets.each do |pet| %>
            <tr>
              <td class="ps-4">
                <% if pet.photo.attached? %>
                  <%= image_tag pet.photo.variant(resize_to_fill: [60, 60]),
                    class: "rounded",
                    style: "width: 60px; height: 60px; object-fit: cover;",
                    alt: "#{pet.name} photo" %>
                <% else %>
                  <div class="rounded bg-light border text-muted d-flex align-items-center justify-content-center"
                       style="width: 60px; height: 60px;">
                    <i class="bi bi-image"></i>
                  </div>
                <% end %>
              </td>

              <td>
                <%= link_to pet.name,
                  pet_path(pet),
                  class: "fw-semibold text-decoration-none" %>
              </td>

              <td>
                <span class="badge bg-secondary-subtle text-secondary">
                  <%= pet.species.capitalize %>
                </span>
              </td>

              <td>
                <span class="text-muted">
                  <%= pet.breed %>
                </span>
              </td>

              <td>
                <%= link_to pet.owner.full_name,
                  owner_path(pet.owner),
                  class: "text-decoration-none" %>
              </td>

              <td>
                <span class="text-muted">
                  <%= format_date(pet.date_of_birth) %>
                </span>
              </td>

              <td class="text-end pe-4">
                <div class="d-flex flex-column flex-md-row justify-content-md-end gap-2">
                  <%= link_to pet_path(pet), class: "btn btn-sm btn-outline-primary" do %>
                    <i class="bi bi-eye me-1"></i>
                    Show
                  <% end %>

                  <%= link_to edit_pet_path(pet), class: "btn btn-sm btn-outline-secondary" do %>
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit
                  <% end %>

                  <%= button_to pet_path(pet),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-sm btn-outline-danger" do %>
                    <i class="bi bi-trash me-1"></i>
                    Delete
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @pets.empty? %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">
                No pets found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>