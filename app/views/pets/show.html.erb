<div class="row g-4">
  <div class="col-12 col-lg-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <h1 class="h3 mb-3"><%= @pet.name %></h1>

        <div class="mb-4">
          <% if @pet.photo.attached? %>
            <%= image_tag @pet.photo,
              class: "img-fluid rounded shadow-sm",
              style: "max-width: 300px; width: 100%; height: auto;",
              alt: "#{@pet.name} photo" %>
          <% else %>
            <div class="border rounded bg-light text-muted d-flex align-items-center justify-content-center"
                 style="max-width: 300px; width: 100%; height: 220px;">
              <div class="text-center">
                <i class="bi bi-image fs-1 d-block mb-2"></i>
                <span>No photo available</span>
              </div>
            </div>
          <% end %>
        </div>

        <p class="mb-2">
          <strong>Species:</strong><br>
          <span class="text-muted"><%= @pet.species.capitalize %></span>
        </p>

        <p class="mb-2">
          <strong>Breed:</strong><br>
          <span class="text-muted"><%= @pet.breed %></span>
        </p>

        <p class="mb-2">
          <strong>Date of Birth:</strong><br>
          <span class="text-muted"><%= format_date(@pet.date_of_birth) %></span>
        </p>

        <p class="mb-2">
          <strong>Weight:</strong><br>
          <span class="text-muted"><%= @pet.weight %> kg</span>
        </p>

        <p class="mb-0">
          <strong>Owner:</strong><br>
          <%= link_to @pet.owner.full_name,
            owner_path(@pet.owner),
            class: "text-decoration-none" %>
        </p>

        <div class="d-grid gap-2 mt-4">
          <%= link_to edit_pet_path(@pet), class: "btn btn-outline-secondary" do %>
            <i class="bi bi-pencil-square me-1"></i>
            Edit Pet
          <% end %>

          <%= button_to pet_path(@pet),
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "btn btn-outline-danger" do %>
            <i class="bi bi-trash me-1"></i>
            Delete Pet
          <% end %>

          <%= link_to pets_path, class: "btn btn-outline-primary" do %>
            <i class="bi bi-arrow-left me-1"></i>
            Back to Pets
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <h2 class="h4 mb-3">Upcoming Appointments</h2>

        <% upcoming_appointments = @pet.appointments.upcoming %>

        <% if upcoming_appointments.any? %>
          <div class="list-group list-group-flush">
            <% upcoming_appointments.each do |appointment| %>
              <%= link_to appointment_path(appointment), class: "list-group-item list-group-item-action px-0" do %>
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <div class="fw-semibold"><%= format_datetime(appointment.date) %></div>
                    <small class="text-muted"><%= human_status(appointment.status) %></small>
                  </div>
                  <span class="text-primary">View</span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0">This pet has no upcoming appointments.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>