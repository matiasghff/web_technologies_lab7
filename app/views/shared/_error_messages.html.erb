<% if object.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <h5 class="alert-heading">
      <%= pluralize(object.errors.count, "error") %> prevented this record from being saved:
    </h5>

    <ul class="mb-0">
      <% object.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>